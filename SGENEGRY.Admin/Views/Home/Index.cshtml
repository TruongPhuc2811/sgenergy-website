@using System.Text.Json
@using SGENERGY.Admin
@using SGENERGY.Admin.Models
@model PagedResult<OrderViewInfo>
@{
    var topProducts = ViewBag.TopProducts as List<KeyValuePair<string, int>> ?? new List<KeyValuePair<string, int>>();
    var monthLabels = ViewBag.MonthLabels ?? new List<string>();
    var monthRevenues = ViewBag.MonthRevenues ?? new List<decimal>();
}

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">@ViewBag.TodayRevenue.ToString("N0") đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng</h6>
                        <h3 class="mb-0">@ViewBag.CompletedOrders</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@ViewBag.TotalCustomers</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@ViewBag.TotalProducts</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-7">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="150"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (topProducts.Any())
                    {
                        @foreach (var p in topProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                @p.Key
                                <span class="badge bg-success">@p.Value</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">Chưa có dữ liệu</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                       @foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td>@item.OrderID</td>
                                <td>@item.CustomerName</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy")</td>
                                <td >@item.SumPrice.ToString("N0") đ</td>
                                @if (item.Status == (OrderStatusEnum)1) {
                                    <td><span class="badge bg-success">Chờ duyệt</span></td>
                                }
                                else if (item.Status == (OrderStatusEnum)2){

                                    <td><span class="badge bg-info-text-dark">Chờ giao hàng</span></td>
                                }
                                <td class="text-center text-nowrap">
                                    <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                        <i class="bi bi-receipt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                       
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = JSON.parse(`@Html.Raw(JsonSerializer.Serialize(monthLabels))`);
        const revenues = JSON.parse(`@Html.Raw(JsonSerializer.Serialize(monthRevenues))`);
        const ctx = document.getElementById("revenueChart");

        if (ctx) {
            new Chart(ctx, {
                type: "bar",
                data: {
                    labels: labels,
                    datasets: [{
                        label: "Doanh thu (đ)",
                        data: revenues,
                        backgroundColor: "rgba(13,110,253,0.7)",
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }
    </script>
}