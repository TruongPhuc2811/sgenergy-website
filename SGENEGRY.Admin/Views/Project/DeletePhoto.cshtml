@model ProjectPhoto
@{
    ViewBag.Title = "Xóa ảnh dự án";
}

@section PageToolBar {
    @if (ViewBag.AllowDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Project/Edit/@Model.ProjectID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa ảnh dự án
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" action="~/Project/DeletePhoto/@Model.ProjectID?photoId=@Model.PhotoID">
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa ảnh này của dự án <strong>@ViewBag.ProjectName</strong> không?
                    </div>

                    <div class="text-center mt-3">
                        <img src="~/images/projects/@Model.Photo"
                             class="img-fluid img-thumbnail"
                             alt="Ảnh dự án"
                             style="max-height:220px;" />
                    </div>
                    <dl class="row mt-3">
                        <dt class="col-sm-3">Mô tả</dt>
                        <dd class="col-sm-9">@Model.Description</dd>
                        <dt class="col-sm-3">Thứ tự hiển thị</dt>
                        <dd class="col-sm-9">@Model.DisplayOrder</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>
