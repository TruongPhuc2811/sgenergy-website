@model Project
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Project" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @Html.ValidationMessage("Error", new { @class = "text-danger" })
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-building me-2"></i>
                    Thông tin dự án
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" enctype="multipart/form-data" action="~/Project/SaveData">
                    <input type="hidden" asp-for="ProjectID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên dự án</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="ProjectName"
                                   class="form-control"
                                   placeholder="" autofocus />
                            <span class="text-danger" asp-validation-for="ProjectName"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa điểm</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="Location" class="form-control" placeholder="" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Chủ đầu tư</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="Investor" class="form-control" placeholder="" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Quy mô</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="ScaleDescription" class="form-control" placeholder="" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" asp-for="DisplayOrder" class="form-control" min="0" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái & Nổi bật</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2 d-inline-block me-4">
                                <input class="form-check-input" asp-for="IsActive"
                                       type="checkbox" id="IsActive" />
                                <label class="form-check-label" for="IsActive">Đang hoạt động</label>
                            </div>
                            <div class="form-check form-switch mt-2 d-inline-block">
                                <input class="form-check-input" asp-for="IsFeatured"
                                       type="checkbox" id="IsFeatured" />
                                <label class="form-check-label" for="IsFeatured">Dự án nổi bật</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            <input type="hidden" asp-for="Thumbnail" />
                            <input type="file" name="uploadThumbnail"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(this)"
                                   data-img-preview="imgPreview" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/projects/@(string.IsNullOrEmpty(Model.Thumbnail) ? "nophoto.png" : Model.Thumbnail)"
                                     class="img-thumbnail"
                                     style="max-height:150px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tóm tắt</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="Summary" rows="3" placeholder=""></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả chi tiết</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="DetailDescription" rows="5" placeholder=""></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@{
    if (Model.ProjectID > 0)
    {
        var photos = ViewBag.ProjectPhotos as List<ProjectPhoto> ?? new List<ProjectPhoto>();
        await Html.RenderPartialAsync("ListPhotos", photos);
    }
}
