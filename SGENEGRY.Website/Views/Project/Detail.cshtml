@using SGENERGY.DomainModels.Sgenergy
@model Project
@{
    ViewData["Title"] = Model.ProjectName;
    var photos = ViewBag.Photos as List<ProjectPhoto> ?? new List<ProjectPhoto>();

    var mainImg = string.IsNullOrWhiteSpace(Model.Thumbnail) || Model.Thumbnail == "nophoto.png"
                  ? "/images/projects/nophoto.png"
                  : $"/images/projects/{Model.Thumbnail}";
}

@await Html.PartialAsync("_PageHero", new SGENERGY.Website.Models.PageHeroVm {
    Title = "CHI TIẾT DỰ ÁN",
    BreadcrumbText = Model.ProjectName,
    BackgroundImageUrl = "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2000&q=70"
})

<section class="project-detail-section" style="padding: 3rem 0; background:#fff;">
    <div class="container">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" style="margin-bottom:1.5rem;">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/du-an">Dự án</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.ProjectName</li>
            </ol>
        </nav>

        <div class="row g-4">

            <!-- ẢNH DỰ ÁN -->
            <div class="col-md-5">
                <div class="project-detail__gallery">
                    <div class="project-detail__main-img">
                        <img id="mainProjectImage" src="@mainImg" alt="@Model.ProjectName"
                             class="img-fluid rounded shadow" loading="eager"
                             onerror="this.src='/images/projects/nophoto.png'" />
                    </div>
                    @if (photos.Any(x => !x.IsHidden))
                    {
                        <div class="project-detail__thumbs" style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.75rem;">
                            <img src="@mainImg" alt="@Model.ProjectName"
                                 class="project-thumb is-active"
                                 onclick="switchImage(this)"
                                 onerror="this.src='/images/projects/nophoto.png'" />
                            @foreach (var ph in photos.Where(x => !x.IsHidden).OrderBy(x => x.DisplayOrder))
                            {
                                var thumbSrc = $"/images/projects/{ph.Photo}";
                                <img src="@thumbSrc" alt="@ph.Description"
                                     class="project-thumb"
                                     onclick="switchImage(this)"
                                     onerror="this.src='/images/projects/nophoto.png'" />
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- THÔNG TIN DỰ ÁN -->
            <div class="col-md-7">
                <h1 class="project-detail__name" style="font-size:1.6rem;font-weight:700;line-height:1.3;margin-bottom:1rem;">
                    @Model.ProjectName
                </h1>

                <table class="table table-bordered table-sm" style="margin-bottom:1.5rem;">
                    <tbody>
                        @if (!string.IsNullOrWhiteSpace(Model.Location))
                        {
                            <tr>
                                <th style="width:35%;background:#f8f9fa;">
                                    <i class="fa-solid fa-location-dot me-2 text-primary"></i>Địa điểm
                                </th>
                                <td>@Model.Location</td>
                            </tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Investor))
                        {
                            <tr>
                                <th style="background:#f8f9fa;">
                                    <i class="fa-solid fa-building me-2 text-primary"></i>Chủ đầu tư
                                </th>
                                <td>@Model.Investor</td>
                            </tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.ScaleDescription))
                        {
                            <tr>
                                <th style="background:#f8f9fa;">
                                    <i class="fa-solid fa-ruler me-2 text-primary"></i>Quy mô
                                </th>
                                <td>@Model.ScaleDescription</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!string.IsNullOrWhiteSpace(Model.Summary))
                {
                    <div class="project-detail__summary" style="color:#555;line-height:1.7;margin-bottom:1.5rem;">
                        <h5 style="font-weight:700;margin-bottom:.5rem;color:var(--color-primary,#1976d2);">
                            <i class="fa-solid fa-circle-info me-2"></i>Tổng quan
                        </h5>
                        <p>@Model.Summary</p>
                    </div>
                }

                <!-- Nút hành động -->
                <div class="project-detail__actions" style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
                    <a href="/lien-he" class="btn btn-primary">
                        <i class="fa-solid fa-phone me-2"></i>Liên hệ tư vấn
                    </a>
                    <a href="/du-an" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>

        <!-- Mô tả chi tiết -->
        @if (!string.IsNullOrWhiteSpace(Model.DetailDescription))
        {
            <div class="project-detail__description mt-4" style="line-height:1.8;color:#444;">
                <h4 style="font-weight:700;margin-bottom:1rem;color:var(--color-primary,#1976d2);">
                    <i class="fa-solid fa-file-lines me-2"></i>Mô tả chi tiết
                </h4>
                @Html.Raw(Html.Encode(Model.DetailDescription).Replace("&#xA;", "<br/>"))
            </div>
        }

        <!-- Album ảnh -->
        @if (photos.Any(x => !x.IsHidden))
        {
            <div class="project-detail__album mt-5">
                <h4 style="font-weight:700;margin-bottom:1rem;color:var(--color-primary,#1976d2);">
                    <i class="fa-solid fa-images me-2"></i>Hình ảnh dự án
                </h4>
                <div class="row g-3">
                    @foreach (var ph in photos.Where(x => !x.IsHidden).OrderBy(x => x.DisplayOrder))
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <img src="/images/projects/@ph.Photo"
                                 alt="@ph.Description"
                                 class="img-fluid rounded shadow-sm"
                                 style="width:100%;height:180px;object-fit:cover;cursor:pointer;"
                                 onclick="switchImage(this)"
                                 onerror="this.src='/images/projects/nophoto.png'" />
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</section>

@section Scripts {
    <style>
        .project-thumb {
            width: 72px;
            height: 72px;
            object-fit: cover;
            border-radius: 6px;
            border: 2px solid #ddd;
            cursor: pointer;
            transition: border-color .2s;
        }
        .project-thumb.is-active,
        .project-thumb:hover { border-color: var(--color-primary, #1976d2); }
        .project-detail__main-img img { max-height: 420px; object-fit: contain; }
    </style>
    <script>
        function switchImage(img) {
            document.getElementById('mainProjectImage').src = img.src;
            document.querySelectorAll('.project-thumb').forEach(t => t.classList.remove('is-active'));
            img.classList.add('is-active');
        }
    </script>
}
