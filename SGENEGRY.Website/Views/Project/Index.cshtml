@using SGENERGY.DomainModels.Sgenergy
@model SGENERGY.DomainModels.Common.PagedResult<Project>
@{
    ViewData["Title"] = "Dự Án";

    string PageUrl(int p) => $"/du-an?page={p}";
}
@await Html.PartialAsync("_PageHero", new SGENERGY.Website.Models.PageHeroVm {
    Title = "DỰ ÁN ĐÃ TRIỂN KHAI",
    BreadcrumbText = "Dự án",
    BackgroundImageUrl = "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2000&q=70"
})
<section class="project-page">
    <div class="container project-page__container">

        <header class="project-header" data-aos="fade-up">
            <span class="project-header__badge">CÁC DỰ ÁN NỔI BẬT MÀ DOANH NGHIỆP ĐÃ TRIỂN KHAI</span>
            <h1 class="project-header__title">DỰ ÁN ĐÃ TRIỂN KHAI</h1>
            <p class="project-header__subtitle">Những dự án năng lượng xanh tiêu biểu đã được chúng tôi triển khai thành công</p>
            
            <div class="project-stats">
                <div class="stat-box" data-aos="fade-up" data-aos-delay="100">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-clipboard-check"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">500+</div>
                        <div class="stat-box__label">Dự án hoàn thành</div>
                    </div>
                </div>
                <div class="stat-box" data-aos="fade-up" data-aos-delay="200">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">300+</div>
                        <div class="stat-box__label">Khách hàng hài lòng</div>
                    </div>
                </div>
                <div class="stat-box" data-aos="fade-up" data-aos-delay="300">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-bolt"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">50MW+</div>
                        <div class="stat-box__label">Tổng công suất lắp đặt</div>
                    </div>
                </div>
                <div class="stat-box" data-aos="fade-up" data-aos-delay="400">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-award"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">10+</div>
                        <div class="stat-box__label">Năm kinh nghiệm</div>
                    </div>
                </div>
            </div>
        </header>

        @if (!Model.DataItems.Any())
        {
            <div class="alert alert-info mt-3">
                <i class="fa-solid fa-circle-info me-2"></i>
                Hiện chưa có dự án nào được đăng tải.
            </div>
        }
        else
        {
            <div class="project-grid">
                @foreach (var p in Model.DataItems)
                {
                    var detailUrl = $"/du-an/{(string.IsNullOrWhiteSpace(p.Slug) ? p.ProjectID.ToString() : p.Slug)}";
                    var imgSrc = string.IsNullOrWhiteSpace(p.Thumbnail) || p.Thumbnail == "nophoto.png"
                                 ? "/images/projects/nophoto.png"
                                 : $"/images/projects/{p.Thumbnail}";
                    <a class="project-card" href="@detailUrl" title="@p.ProjectName" data-aos="zoom-in">
                        <div class="project-card__img">
                            <img src="@imgSrc"
                                 alt="@p.ProjectName"
                                 loading="lazy"
                                 onerror="this.src='/images/projects/nophoto.png'" />
                            <div class="project-card__hover">
                                <div class="project-card__icon">
                                    <i class="fa-solid fa-plus"></i>
                                </div>
                            </div>
                        </div>

                        <div class="project-card__overlay">
                            <div class="project-card__content">
                                <span class="project-card__category">
                                    <i class="fa-solid fa-tag"></i>
                                    Năng lượng xanh
                                </span>
                                <h3 class="project-card__name">@p.ProjectName</h3>
                                <div class="project-card__meta">
                                    @if (!string.IsNullOrWhiteSpace(p.Location))
                                    {
                                        <span class="meta-item">
                                            <i class="fa-solid fa-location-dot"></i>
                                            @p.Location
                                        </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(p.Investor))
                                    {
                                        <span class="meta-item">
                                            <i class="fa-solid fa-building"></i>
                                            @p.Investor
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="project-card__arrow">
                                <i class="fa-solid fa-arrow-right"></i>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <!-- Phân trang -->
            @if (Model.PageCount > 1)
            {
                <nav class="pagination project-pagination" aria-label="Phân trang" data-aos="fade-up">
                    @if (Model.HasPreviousPage)
                    {
                        <a class="page-btn page-btn--prev" href="@PageUrl(Model.Page - 1)" aria-label="Trang trước">
                            <i class="fa-solid fa-chevron-left"></i><span>Trước</span>
                        </a>
                    }
                    @foreach (var pg in Model.GetDisplayPages())
                    {
                        if (pg.IsEllipsis)
                        {
                            <span class="page-dots">…</span>
                        }
                        else
                        {
                            <a class="page-btn @(pg.IsCurrent ? "is-active" : "")"
                               href="@PageUrl(pg.Page)">@pg.Page</a>
                        }
                    }
                    @if (Model.HasNextPage)
                    {
                        <a class="page-btn page-btn--next" href="@PageUrl(Model.Page + 1)" aria-label="Trang sau">
                            <span>Sau</span><i class="fa-solid fa-chevron-right"></i>
                        </a>
                    }
                </nav>
            }
        }

    </div>
</section>

@section Scripts {
    <script src="~/js/project.js" asp-append-version="true"></script>
}