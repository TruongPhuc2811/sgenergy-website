@model SGENERGY.Website.Models.ProjectListVm
@{
    ViewData["Title"] = "Dự Án";
}
@await Html.PartialAsync("_PageHero", new PageHeroVm {
Title = "DỰ ÁN ĐÃ TRIỂN KHAI",
    BreadcrumbText = "Dự án",
    BackgroundImageUrl = "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2000&q=70"
})
<section class="project-page">
    <div class="container project-page__container">

        <header class="project-header" data-aos="fade-up">
            @if (!string.IsNullOrWhiteSpace(Model.HeadingSmall))
            {
                <span class="project-header__badge">@Model.HeadingSmall</span>
            }
            <h1 class="project-header__title">@Model.HeadingLarge</h1>
            <p class="project-header__subtitle">Những dự án năng lượng xanh tiêu biểu đã được chúng tôi triển khai thành công</p>
            
            <div class="project-stats">
                <div class="stat-box" data-aos="fade-up" data-aos-delay="100">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-clipboard-check"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">500+</div>
                        <div class="stat-box__label">Dự án hoàn thành</div>
                    </div>
                </div>
                <div class="stat-box" data-aos="fade-up" data-aos-delay="200">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">300+</div>
                        <div class="stat-box__label">Khách hàng hài lòng</div>
                    </div>
                </div>
                <div class="stat-box" data-aos="fade-up" data-aos-delay="300">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-bolt"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">50MW+</div>
                        <div class="stat-box__label">Tổng công suất lắp đặt</div>
                    </div>
                </div>
                <div class="stat-box" data-aos="fade-up" data-aos-delay="400">
                    <div class="stat-box__icon">
                        <i class="fa-solid fa-award"></i>
                    </div>
                    <div class="stat-box__content">
                        <div class="stat-box__number">10+</div>
                        <div class="stat-box__label">Năm kinh nghiệm</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="project-filter" data-aos="fade-up">
            <div class="filter-label">
                <i class="fa-solid fa-filter"></i>
                <span>Lọc theo:</span>
            </div>
            <div class="filter-buttons">
                <button class="filter-btn is-active" data-filter="all">
                    <i class="fa-solid fa-layer-group"></i>
                    Tất cả
                </button>
                <button class="filter-btn" data-filter="residential">
                    <i class="fa-solid fa-house"></i>
                    Hộ gia đình
                </button>
                <button class="filter-btn" data-filter="commercial">
                    <i class="fa-solid fa-building"></i>
                    Thương mại
                </button>
                <button class="filter-btn" data-filter="industrial">
                    <i class="fa-solid fa-industry"></i>
                    Công nghiệp
                </button>
            </div>
        </div>

        <div class="project-grid">
            @foreach (var p in Model.Projects)
            {
                <a class="project-card" href="@p.DetailUrl" title="@p.Title" data-aos="zoom-in">
                    <div class="project-card__img">
                        <img src="@p.ImageUrl"
                             alt="@p.Title"
                             loading="lazy"
                             referrerpolicy="no-referrer" />
                        <div class="project-card__hover">
                            <div class="project-card__icon">
                                <i class="fa-solid fa-plus"></i>
                            </div>
                        </div>
                    </div>

                    <div class="project-card__overlay">
                        <div class="project-card__content">
                            <span class="project-card__category">
                                <i class="fa-solid fa-tag"></i>
                                Năng lượng xanh
                            </span>
                            <h3 class="project-card__name">@p.Title</h3>
                            <div class="project-card__meta">
                                <span class="meta-item">
                                    <i class="fa-solid fa-location-dot"></i>
                                    TP. Hồ Chí Minh
                                </span>
                                <span class="meta-item">
                                    <i class="fa-solid fa-calendar"></i>
                                    2026
                                </span>
                            </div>
                        </div>
                        <div class="project-card__arrow">
                            <i class="fa-solid fa-arrow-right"></i>
                        </div>
                    </div>
                </a>
            }
        </div>

        <nav class="pagination project-pagination" aria-label="Pagination" data-aos="fade-up">
            <a class="page-btn page-btn--prev" href="#" aria-label="Previous">
                <i class="fa-solid fa-chevron-left"></i>
                <span>Trước</span>
            </a>
            <a class="page-btn is-active" href="#">1</a>
            <a class="page-btn" href="#">2</a>
            <a class="page-btn" href="#">3</a>
            <a class="page-btn" href="#">4</a>
            <a class="page-btn" href="#">5</a>
            <a class="page-btn page-btn--next" href="#" aria-label="Next">
                <span>Sau</span>
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </nav>

    </div>
</section>

@section Scripts {
    <script src="~/js/project.js" asp-append-version="true"></script>
}