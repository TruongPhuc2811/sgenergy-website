@{
    ViewData["Title"] = "Giải pháp";
}

<section class="solutions-hero" style="--hero-img:url('https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2000&q=70')">
    <div class="solutions-hero__overlay"></div>

    <div class="solutions-hero__content container" data-aos="fade-up">
        <span class="hero-badge">Giải pháp toàn diện</span>
        <h1 class="solutions-hero__title">GIẢI PHÁP<br/><span class="highlight">DOANH NGHIỆP</span></h1>
        <p class="solutions-hero__subtitle">Tối ưu hóa chi phí - Gia tăng hiệu suất - Phát triển bền vững</p>
        <div class="solutions-hero__crumb">
            <a href="/"><i class="fa-solid fa-house"></i> Trang chủ</a>
            <span><i class="fa-solid fa-chevron-right"></i></span>
            <span>Giải pháp doanh nghiệp</span>
        </div>
    </div>
</section>

<!-- Sticky topbar (scrollspy) -->
<nav class="solutions-nav js-solutions-nav" aria-label="Solutions sections">
    <div class="container solutions-nav__inner">
        <a class="solutions-nav__link is-active" href="#goi-giai-phap" data-target="goi-giai-phap">
            <i class="fa-solid fa-box"></i>
            <span>GÓI GIẢI PHÁP</span>
        </a>
        <a class="solutions-nav__link" href="#loi-ich" data-target="loi-ich">
            <i class="fa-solid fa-star"></i>
            <span>LỢI ÍCH KHÁC BIỆT</span>
        </a>
        <a class="solutions-nav__link" href="#hau-mai" data-target="hau-mai">
            <i class="fa-solid fa-shield-halved"></i>
            <span>BẢO TRÌ HẬU MÃI</span>
        </a>
        <a class="solutions-nav__link" href="#quy-trinh" data-target="quy-trinh">
            <i class="fa-solid fa-list-check"></i>
            <span>QUY TRÌNH</span>
        </a>
        <a class="solutions-nav__link" href="#ly-do" data-target="ly-do">
            <i class="fa-solid fa-thumbs-up"></i>
            <span>LÝ DO CHỌN SG ENERGY</span>
        </a>
    </div>
</nav>

<main class="solutions-main">

    <!-- Intro / Banner like your screenshot -->
    <section class="solutions-intro" id="goi-giai-phap" data-spy-section>
        <div class="container solutions-intro__wrap">
            <div class="solutions-intro__left" data-aos="fade-right">
                <span class="section-badge">Về giải pháp</span>
                <h2 class="solutions-intro__title">Giải pháp<br/><span class="highlight">doanh nghiệp</span></h2>

                <p class="solutions-intro__text">
                    Hiện nay các nhà máy, xí nghiệp, công ty, nhà xưởng đang tiêu tốn một lượng điện năng quá lớn.
                    Chi phí phải trả cho hóa đơn điện năng hàng tháng chiếm một phần lớn chi phí sản xuất.
                </p>
                <p class="solutions-intro__text">
                    Một giải pháp ưu việt để tiết kiệm chi phí đó chính là lắp đặt điện mặt trời cho doanh nghiệp,
                    giúp tối ưu chi phí và phát triển bền vững.
                </p>

                <div class="solutions-intro__features">
                    <div class="feature-badge">
                        <i class="fa-solid fa-check-circle"></i>
                        <span>Tiết kiệm đến 70% chi phí điện</span>
                    </div>
                    <div class="feature-badge">
                        <i class="fa-solid fa-check-circle"></i>
                        <span>Hoàn vốn nhanh chóng 4-6 năm</span>
                    </div>
                    <div class="feature-badge">
                        <i class="fa-solid fa-check-circle"></i>
                        <span>Bảo hành lên đến 25 năm</span>
                    </div>
                </div>

                <p class="solutions-intro__cta">
                    <i class="fa-solid fa-lightbulb"></i>
                    Đừng để bị bỏ lại phía sau. Hãy tham gia sử dụng điện mặt trời ngay bây giờ!
                </p>
                
                <div class="solutions-intro__actions">
                    <a href="~/lien-he" class="btn-primary btn-icon">
                        <span>Nhận tư vấn miễn phí</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <a href="#quy-trinh" class="btn-secondary">
                        <i class="fa-solid fa-play"></i>
                        <span>Xem quy trình</span>
                    </a>
                </div>
            </div>

            <div class="solutions-intro__right" aria-hidden="true" data-aos="fade-left">
                <div class="solutions-intro__bg"
                     style="background-image:url('https://images.unsplash.com/photo-1509395176047-4a66953fd231?auto=format&fit=crop&w=1600&q=70')">
                    <div class="solutions-intro__overlay"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Packages: 7 demo solutions -->
    <section class="solutions-packages" aria-label="Gói giải pháp">
        <div class="container">
            <header class="section-head" data-aos="fade-up">
                <span class="section-head__kicker">CÁC GÓI GIẢI PHÁP DEMO</span>
                <h2 class="section-head__title">Giải pháp phù hợp<br/>cho mọi nhu cầu</h2>
                <p class="section-head__desc">Lựa chọn giải pháp phù hợp nhất với nhu cầu và quy mô của bạn</p>
            </header>

            <div class="package-grid">
                <article class="package-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="package-card__icon">
                        <i class="fa-solid fa-house"></i>
                    </div>
                    <div class="package-card__tag package-card__tag--popular">Phổ biến</div>
                    <h3 class="package-card__title">Giải pháp hộ gia đình</h3>
                    <p class="package-card__desc">Tối ưu chi phí điện sinh hoạt, hoàn vốn nhanh, vận hành bền bỉ.</p>
                    <ul class="package-card__features">
                        <li><i class="fa-solid fa-check"></i> Công suất: 3-10 kW</li>
                        <li><i class="fa-solid fa-check"></i> Tiết kiệm 50-70%</li>
                        <li><i class="fa-solid fa-check"></i> Hoàn vốn: 4-6 năm</li>
                    </ul>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="HoGiaDinh">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>

                <article class="package-card">
                    <div class="package-card__tag">Doanh nghiệp</div>
                    <h3 class="package-card__title">Giải pháp văn phòng công ty</h3>
                    <p class="package-card__desc">Ổn định nguồn điện, giảm chi phí vận hành, tăng hình ảnh “xanh”.</p>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="VanPhongCongTy">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>

                <article class="package-card">
                    <div class="package-card__tag">Công nghiệp</div>
                    <h3 class="package-card__title">Giải pháp công xưởng, nhà máy</h3>
                    <p class="package-card__desc">Thiết kế theo tải tiêu thụ, tối ưu hiệu suất, giám sát thông minh.</p>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="CongXuongNhaMay">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>

                <article class="package-card">
                    <div class="package-card__tag">Thiết bị</div>
                    <h3 class="package-card__title">Pin năng lượng mặt trời</h3>
                    <p class="package-card__desc">Tấm pin hiệu suất cao, tiêu chuẩn quốc tế, bảo hành lâu dài.</p>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="PinNangLuongMatTroi">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>

                <article class="package-card">
                    <div class="package-card__tag">Tuần hoàn</div>
                    <h3 class="package-card__title">Giải pháp tái chế sơ cấp</h3>
                    <p class="package-card__desc">Tái sử dụng tài nguyên, giảm phát thải, tối ưu chi phí xử lý.</p>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="TaiCheSoCap">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>

                <article class="package-card">
                    <div class="package-card__tag">Môi trường</div>
                    <h3 class="package-card__title">Giải pháp xử lý chất thải</h3>
                    <p class="package-card__desc">Tư vấn – thiết kế – thi công, đáp ứng tiêu chuẩn môi trường.</p>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="XuLyChatThai">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>

                <article class="package-card">
                    <div class="package-card__tag">Tiết kiệm</div>
                    <h3 class="package-card__title">Giải pháp tiết kiệm năng lượng</h3>
                    <p class="package-card__desc">Khảo sát và đề xuất phương án giảm tiêu hao, tối ưu vận hành.</p>
                    <a class="package-card__btn" asp-controller="Solution" asp-action="TietKiemNangLuong">
                        <span>Xem chi tiết</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </article>
            </div>
        </div>
    </section>

    <!-- Benefits (icon grid like screenshot) -->
    <section class="solutions-benefits" id="loi-ich" data-spy-section>
        <div class="container">
            <header class="section-head section-head--left">
                <div class="section-head__kicker">TẠI SAO NÊN SỬ DỤNG?</div>
                <h2 class="section-head__title">LỢI ÍCH KHÁC BIỆT</h2>
            </header>

            <div class="benefit-grid">
                <div class="benefit">
                    <div class="benefit__icon"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                    <div class="benefit__title">LINH HOẠT CHI PHÍ ĐẦU TƯ</div>
                    <div class="benefit__desc">Đa dạng mô hình tài chính, phù hợp ngân sách và nhu cầu.</div>
                </div>

                <div class="benefit">
                    <div class="benefit__icon"><i class="fa-solid fa-piggy-bank"></i></div>
                    <div class="benefit__title">UY TÍN – CHẤT LƯỢNG</div>
                    <div class="benefit__desc">Cam kết thiết bị chính hãng, tiêu chuẩn rõ ràng.</div>
                </div>

                <div class="benefit">
                    <div class="benefit__icon"><i class="fa-solid fa-shield-heart"></i></div>
                    <div class="benefit__title">KIỂM CHỨNG TIN CẬY</div>
                    <div class="benefit__desc">Hệ thống được nghiệm thu theo quy trình kỹ thuật.</div>
                </div>

                <div class="benefit">
                    <div class="benefit__icon"><i class="fa-solid fa-award"></i></div>
                    <div class="benefit__title">KINH NGHIỆM TRIỂN KHAI</div>
                    <div class="benefit__desc">Đội ngũ kỹ sư giàu kinh nghiệm, thi công an toàn.</div>
                </div>

                <div class="benefit">
                    <div class="benefit__icon"><i class="fa-solid fa-leaf"></i></div>
                    <div class="benefit__title">BẢO VỆ MÔI TRƯỜNG</div>
                    <div class="benefit__desc">Giảm phát thải CO₂, hướng tới phát triển bền vững.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- After-sales / Maintenance (blue section like screenshot) -->
    <section class="solutions-after" id="hau-mai" data-spy-section
             style="--after-img:url('https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?auto=format&fit=crop&w=2000&q=70')">
        <div class="solutions-after__overlay"></div>

        <div class="container solutions-after__wrap">
            <div class="after-badges" aria-label="Bảo hành">
                <div class="after-badge">
                    <div class="after-badge__num">25</div>
                    <div class="after-badge__txt">năm<br />Bảo hành hiệu suất tấm pin</div>
                </div>
                <div class="after-badge">
                    <div class="after-badge__num">10</div>
                    <div class="after-badge__txt">năm<br />Bảo hành tấm pin</div>
                </div>
                <div class="after-badge">
                    <div class="after-badge__num">05</div>
                    <div class="after-badge__txt">năm<br />Bảo hành inverter</div>
                </div>
                <div class="after-badge">
                    <div class="after-badge__num">05</div>
                    <div class="after-badge__txt">năm<br />Bảo hành hệ khung</div>
                </div>
            </div>

            <div class="after-content">
                <h2 class="after-content__title">BẢO TRÌ HẬU MÃI</h2>
                <p>
                    Với quy trình và chính sách hỗ trợ kỹ thuật 24/7, SG Energy cam kết tiếp nhận và xử lý nhanh
                    các yêu cầu sau bán hàng.
                </p>
                <p>
                    Đội ngũ kỹ thuật luôn đồng hành cùng khách hàng trong suốt quá trình vận hành nhằm tối ưu hiệu suất hệ thống.
                </p>

                <a class="after-content__link" href="/lien-he">
                    <span>Liên hệ để biết thêm</span>
                    <span class="after-content__arrow"><i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
        </div>
    </section>

    <!-- Process (timeline like screenshot) -->
    <section class="solutions-process" id="quy-trinh" data-spy-section>
        <div class="container">
            <header class="section-head section-head--center">
                <div class="section-head__kicker">THI CÔNG AN TOÀN, LẮP ĐẶT NHANH CHÓNG</div>
                <h2 class="section-head__title">QUY TRÌNH THỰC HIỆN</h2>
            </header>

            <div class="process-row">
                <button class="process-nav" type="button" aria-label="Prev">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>

                <div class="process-steps">
                    <div class="process-step is-active">
                        <div class="process-step__diamond"><i class="fa-regular fa-comments"></i></div>
                        <div class="process-step__text">Tiếp nhận yêu cầu<br />khách hàng</div>
                    </div>

                    <div class="process-step">
                        <div class="process-step__diamond"><i class="fa-solid fa-ruler-combined"></i></div>
                        <div class="process-step__text">Khảo sát &amp; đo đạc<br />chính xác (1 ngày)</div>
                    </div>

                    <div class="process-step">
                        <div class="process-step__diamond"><i class="fa-regular fa-file-lines"></i></div>
                        <div class="process-step__text">Báo giá gói<br />(1 ngày)</div>
                    </div>

                    <div class="process-step">
                        <div class="process-step__diamond"><i class="fa-regular fa-pen-to-square"></i></div>
                        <div class="process-step__text">Ký hợp đồng<br />(tùy thuộc)</div>
                    </div>

                    <div class="process-step">
                        <div class="process-step__diamond"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                        <div class="process-step__text">Lắp đặt nhanh<br />vận hành mượt (7–10 ngày)</div>
                    </div>
                </div>

                <button class="process-nav" type="button" aria-label="Next">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </section>

    <!-- Reasons (blue background cards like screenshot) -->
    <section class="solutions-reasons" id="ly-do" data-spy-section
             style="--reasons-img:url('https://images.unsplash.com/photo-1509395176047-4a66953fd231?auto=format&fit=crop&w=2000&q=70')">
        <div class="solutions-reasons__overlay"></div>

        <div class="container solutions-reasons__wrap">
            <h2 class="reasons-title">LÝ DO CHỌN SG ENERGY</h2>

            <div class="reasons-cards">
                <article class="reason-card">
                    <div class="reason-card__num">01</div>
                    <div class="reason-card__title">Kinh nghiệm &amp; năng lực triển khai</div>
                    <div class="reason-card__desc">
                        Đội ngũ kỹ thuật giàu kinh nghiệm, quy trình chuẩn, thi công an toàn và đúng tiến độ.
                    </div>
                </article>

                <article class="reason-card">
                    <div class="reason-card__num">02</div>
                    <div class="reason-card__title">Cam kết đồng hành dài hạn</div>
                    <div class="reason-card__desc">
                        Hậu mãi rõ ràng, hỗ trợ kỹ thuật nhanh chóng, tối ưu hiệu suất vận hành.
                    </div>
                </article>

                <article class="reason-card">
                    <div class="reason-card__num">03</div>
                    <div class="reason-card__title">Thiết bị chính hãng, tiêu chuẩn quốc tế</div>
                    <div class="reason-card__desc">
                        Lựa chọn thiết bị uy tín, chứng nhận đầy đủ, phù hợp từng nhu cầu sử dụng.
                    </div>
                </article>
            </div>
        </div>
    </section>

</main>

@section Scripts {
    <script src="~/js/solutions.js" asp-append-version="true"></script>
}