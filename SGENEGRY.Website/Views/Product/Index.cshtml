@model SGENERGY.Website.Models.ProductListVm
@{
    ViewData["Title"] = Model.Title;
}
@await Html.PartialAsync("_PageHero", new PageHeroVm {
Title = "SẢN PHẨM",
    BreadcrumbText = "Sản phẩm",
    BackgroundImageUrl = "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2000&q=70"
})
<section class="product-page">
    <div class="container product-page__container">

        <!-- SIDEBAR -->
        <aside class="product-sidebar" data-aos="fade-right">

            <div class="sidebar-block js-accordion is-open">
                <button class="sidebar-block__header js-accordion-btn" type="button">
                    <div class="sidebar-block__icon">
                        <i class="fa-solid fa-list"></i>
                    </div>
                    <span class="sidebar-block__title">DANH MỤC SẢN PHẨM</span>
                    <span class="chev"><i class="fa-solid fa-chevron-down"></i></span>
                </button>

                <div class="sidebar-block__body js-accordion-body">
                    @foreach (var c in Model.Categories)
                    {
                        <a class="sidebar-link @(c.IsActive ? "is-active" : "")" href="@c.Url">
                            <span class="sidebar-link__icon"><i class="fa-solid fa-angle-right"></i></span>
                            <span class="sidebar-link__text">@c.Name</span>
                            @if (c.IsActive)
                            {
                                <span class="sidebar-link__badge"><i class="fa-solid fa-check"></i></span>
                            }
                        </a>
                    }
                </div>
            </div>

            <div class="sidebar-block js-accordion is-open">
                <button class="sidebar-block__header js-accordion-btn" type="button">
                    <div class="sidebar-block__icon">
                        <i class="fa-solid fa-filter"></i>
                    </div>
                    <span class="sidebar-block__title">LỌC SẢN PHẨM</span>
                    <span class="chev"><i class="fa-solid fa-chevron-down"></i></span>
                </button>

                <div class="sidebar-block__body js-accordion-body">
                    <div class="filter-row">
                        <button class="filter-row__btn" type="button">
                            <i class="fa-solid fa-bolt"></i>
                            <span>Công suất</span>
                            <i class="fa-solid fa-angle-down"></i>
                        </button>
                    </div>
                    <div class="filter-row">
                        <button class="filter-row__btn" type="button">
                            <i class="fa-solid fa-building"></i>
                            <span>Thương hiệu</span>
                            <i class="fa-solid fa-angle-down"></i>
                        </button>
                    </div>
                    <div class="filter-row">
                        <button class="filter-row__btn" type="button">
                            <i class="fa-solid fa-layer-group"></i>
                            <span>Chủng loại</span>
                            <i class="fa-solid fa-angle-down"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="sidebar-block js-accordion is-open">
                <button class="sidebar-block__header js-accordion-btn" type="button">
                    <div class="sidebar-block__icon">
                        <i class="fa-solid fa-sparkles"></i>
                    </div>
                    <span class="sidebar-block__title">SẢN PHẨM MỚI</span>
                    <span class="chev"><i class="fa-solid fa-chevron-down"></i></span>
                </button>

                <div class="sidebar-block__body js-accordion-body sidebar-new">
                    @foreach (var p in Model.NewProducts)
                    {
                        <a class="sidebar-new__item" href="@p.DetailUrl">
                            <div class="sidebar-new__image">
                                <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" referrerpolicy="no-referrer" />
                                <span class="sidebar-new__badge">Mới</span>
                            </div>
                            <div class="sidebar-new__meta">
                                <div class="sidebar-new__name">@p.Name</div>
                                <div class="sidebar-new__more">
                                    <span>Xem chi tiết</span>
                                    <i class="fa-solid fa-arrow-right"></i>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>

        </aside>

        <!-- MAIN -->
        <main class="product-main" id="productMain" data-aos="fade-left">
            <div class="product-main__top">
                <div class="product-header">
                    <h1 class="product-title">@Model.Title</h1>
                    <p class="product-count">
                        <i class="fa-solid fa-box"></i>
                        Hiển thị <strong>@Model.Products.Count()</strong> sản phẩm
                    </p>
                </div>

                <div class="product-toolbar">
                    <div class="product-toolbar__group">
                        <label for="sortSelect" class="toolbar-label">
                            <i class="fa-solid fa-sort"></i>
                            Sắp xếp:
                        </label>
                        <select id="sortSelect" class="product-toolbar__select" aria-label="Sắp xếp">
                            <option>Mới nhất</option>
                            <option>Phổ biến nhất</option>
                            <option>Giá tăng dần</option>
                            <option>Giá giảm dần</option>
                        </select>
                    </div>

                    <div class="product-toolbar__group">
                        <label class="toolbar-label">
                            <i class="fa-solid fa-eye"></i>
                            Hiển thị:
                        </label>
                        <div class="product-toolbar__views" aria-label="Chế độ hiển thị">
                            <button class="view-btn is-active" data-view="grid" type="button" title="Grid">
                                <i class="fa-solid fa-table-cells"></i>
                            </button>
                            <button class="view-btn" data-view="list" type="button" title="List">
                                <i class="fa-solid fa-bars"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="product-grid js-product-grid" data-view="grid">
                @foreach (var p in Model.Products)
                {
                    <article class="product-card">
                        <a class="product-card__img" href="@p.DetailUrl">
                            @if (!string.IsNullOrWhiteSpace(p.BadgeText))
                            {
                                <span class="product-badge product-badge--special">@p.BadgeText</span>
                            }
                            <img src="@p.ImageUrl"
                                 alt="@p.Name"
                                 loading="lazy"
                                 referrerpolicy="no-referrer" />
                            <div class="product-card__overlay">
                                <div class="product-card__actions">
                                    <button class="product-action" title="Thêm vào yêu thích">
                                        <i class="fa-regular fa-heart"></i>
                                    </button>
                                    <button class="product-action" title="Xem nhanh">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                    <button class="product-action" title="So sánh">
                                        <i class="fa-solid fa-code-compare"></i>
                                    </button>
                                </div>
                            </div>
                        </a>

                        <div class="product-card__content">
                            <h3 class="product-card__name">
                                <a href="@p.DetailUrl">@p.Name</a>
                            </h3>
                            
                            <div class="product-card__rating">
                                <div class="rating-stars">
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star-half-stroke"></i>
                                </div>
                                <span class="rating-count">(4.5)</span>
                            </div>

                            <div class="product-card__footer">
                                <a class="product-card__btn" href="@p.DetailUrl">
                                    <span>Xem chi tiết</span>
                                    <i class="fa-solid fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <nav class="pagination" aria-label="Pagination">
                <a class="page-btn page-btn--prev" href="#" aria-label="Previous">
                    <i class="fa-solid fa-chevron-left"></i>
                    <span>Trước</span>
                </a>
                <a class="page-btn is-active" href="#">1</a>
                <a class="page-btn" href="#">2</a>
                <a class="page-btn" href="#">3</a>
                <span class="page-dots">…</span>
                <a class="page-btn" href="#">10</a>
                <a class="page-btn page-btn--next" href="#" aria-label="Next">
                    <span>Sau</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            </nav>
        </main>
    </div>
</section>

@section Scripts {
    <script src="~/js/products.js" asp-append-version="true"></script>

}