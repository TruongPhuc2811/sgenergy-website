@using SGENERGY.DomainModels.Catalog
@using SGENERGY.DomainModels.Partner
@model Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos     = ViewBag.Photos     as List<ProductPhoto>     ?? new List<ProductPhoto>();
    var attributes = ViewBag.Attributes as List<ProductAttribute> ?? new List<ProductAttribute>();
    var category   = ViewBag.Category   as Category;
    var supplier   = ViewBag.Supplier   as Supplier;

    var mainImg = string.IsNullOrWhiteSpace(Model.Photo) || Model.Photo == "nophoto.png"
                  ? "/images/products/nophoto.png"
                  : $"/images/products/{Model.Photo}";
}

@await Html.PartialAsync("_PageHero", new SGENERGY.Website.Models.PageHeroVm {
    Title = "CHI TIẾT SẢN PHẨM",
    BreadcrumbText = Model.ProductName,
    BackgroundImageUrl = "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2000&q=70"
})

<section class="product-detail-section" style="padding: 3rem 0; background:#fff;">
    <div class="container">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" style="margin-bottom:1.5rem;">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/san-pham">Sản phẩm</a></li>
                @if (category != null)
                {
                    <li class="breadcrumb-item">
                        <a href="/san-pham/loai-hang/@(category.Slug ?? category.CategoryID.ToString())">@category.CategoryName</a>
                    </li>
                }
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>

        <div class="row g-4">

            <!-- ẢNH SẢN PHẨM -->
            <div class="col-md-5">
                <div class="product-detail__gallery">
                    <div class="product-detail__main-img">
                        <img id="mainProductImage" src="@mainImg" alt="@Model.ProductName"
                             class="img-fluid rounded shadow" loading="eager"
                             onerror="this.src='/images/products/nophoto.png'" />
                    </div>
                    @if (photos.Any())
                    {
                        <div class="product-detail__thumbs" style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.75rem;">
                            <img src="@mainImg" alt="@Model.ProductName"
                                 class="product-thumb is-active"
                                 onclick="switchImage(this)"
                                 onerror="this.src='/images/products/nophoto.png'" />
                            @foreach (var ph in photos.Where(x => !x.IsHidden))
                            {
                                var thumbSrc = $"/images/products/{ph.Photo}";
                                <img src="@thumbSrc" alt="@ph.Description"
                                     class="product-thumb"
                                     onclick="switchImage(this)"
                                     onerror="this.src='/images/products/nophoto.png'" />
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- THÔNG TIN SẢN PHẨM -->
            <div class="col-md-7">
                <h1 class="product-detail__name" style="font-size:1.6rem;font-weight:700;line-height:1.3;margin-bottom:.75rem;">
                    @Model.ProductName
                </h1>

                <div class="product-detail__meta" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                    @if (category != null)
                    {
                        <a href="/san-pham/loai-hang/@(category.Slug ?? category.CategoryID.ToString())"
                           class="badge bg-primary text-decoration-none">
                            <i class="fa-solid fa-tag me-1"></i>@category.CategoryName
                        </a>
                    }
                    @if (supplier != null)
                    {
                        <a href="/san-pham/hang/@(supplier.Slug ?? supplier.SupplierID.ToString())"
                           class="badge bg-secondary text-decoration-none">
                            <i class="fa-solid fa-building me-1"></i>@supplier.SupplierName
                        </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Unit))
                    {
                        <span class="badge bg-light text-dark border">
                            <i class="fa-solid fa-ruler me-1"></i>ĐVT: @Model.Unit
                        </span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ProductDescription))
                {
                    <div class="product-detail__desc" style="color:#555;line-height:1.7;margin-bottom:1.5rem;">
                        @Html.Raw(Model.ProductDescription!.Replace("\n", "<br/>"))
                    </div>
                }

                <!-- Nút liên hệ -->
                <div class="product-detail__actions" style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
                    <a href="/lien-he" class="btn btn-primary">
                        <i class="fa-solid fa-phone me-2"></i>Liên hệ báo giá
                    </a>
                    <a href="/san-pham" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại danh sách
                    </a>
                </div>

                <!-- Thuộc tính kỹ thuật -->
                @if (attributes.Any())
                {
                    <div class="product-detail__attributes">
                        <h5 style="font-weight:700;margin-bottom:.75rem;color:var(--color-primary,#1976d2);">
                            <i class="fa-solid fa-list-check me-2"></i>Thông số kỹ thuật
                        </h5>
                        <table class="table table-bordered table-sm">
                            <tbody>
                                @foreach (var attr in attributes.OrderBy(a => a.DisplayOrder))
                                {
                                    <tr>
                                        <th style="width:40%;background:#f8f9fa;">@attr.AttributeName</th>
                                        <td>@attr.AttributeValue</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <style>
        .product-thumb {
            width: 72px;
            height: 72px;
            object-fit: cover;
            border-radius: 6px;
            border: 2px solid #ddd;
            cursor: pointer;
            transition: border-color .2s;
        }
        .product-thumb.is-active,
        .product-thumb:hover { border-color: var(--color-primary, #1976d2); }
        .product-detail__main-img img { max-height: 420px; object-fit: contain; }
    </style>
    <script>
        function switchImage(thumb) {
            document.getElementById('mainProductImage').src = thumb.src;
            document.querySelectorAll('.product-thumb').forEach(t => t.classList.remove('is-active'));
            thumb.classList.add('is-active');
        }
    </script>
}
